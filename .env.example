# Primary provider (preferred). Get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Fallback provider — used automatically if the Anthropic key has no billing/credits.
# Add up to 3 Gemini keys; free-tier quota is per-key, so Kavi rotates across them
# and cools any key that hits a quota limit. Get keys from aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-key-1
GOOGLE_GENERATIVE_AI_API_KEY_2=your-gemini-key-2
GOOGLE_GENERATIVE_AI_API_KEY_3=your-gemini-key-3
# Alternative: one comma-separated line (overrides nothing, merged + deduped)
# GEMINI_API_KEYS=key1,key2,key3

# Optional model overrides
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# GEMINI_MODEL=gemini-2.5-flash
